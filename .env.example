# Copy to .env.local and fill in. .env.local is gitignored.
# On Netlify, set these three in Site configuration → Environment variables.

# Your Anthropic API key (sk-ant-...). Server-side only; never shipped to the client.
ANTHROPIC_API_KEY=

# Shared-secret guard. Use the SAME value for both. Generate one with:
#   openssl rand -hex 32
# ANTHROPIC_PROXY_SECRET is validated server-side by the Netlify function.
# VITE_PROXY_SECRET is baked into the client build (PUBLIC — readable in the
# bundle) and sent as the x-proxy-secret header. This guard only blocks naive
# direct calls; it is not real authentication.
ANTHROPIC_PROXY_SECRET=
VITE_PROXY_SECRET=
